{
  "name": "snapper-frontend",
  "private": true,
  "version": "1.5.6",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateusz-klatt/snapper-frontend.git"
  },
  "homepage": "https://github.com/mateusz-klatt/snapper-frontend#readme",
  "bugs": {
    "url": "https://github.com/mateusz-klatt/snapper-frontend/issues"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "eslint --cache . --fix",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dead-code": "knip",
    "dead-code:fix": "knip --fix",
    "check:no-comments": "node scripts/check-no-comments.mjs",
    "check:no-comments:strict": "node scripts/check-no-comments.mjs --strict",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:serial": "vitest run --maxWorkers=1 --no-file-parallelism",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:serial": "vitest run --coverage --maxWorkers=1 --no-file-parallelism",
    "prepush": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm check:no-comments:strict && pnpm test:coverage",
    "prepush:fix": "pnpm format && pnpm lint --fix && pnpm typecheck && pnpm check:no-comments:strict && pnpm test:coverage",
    "gen:api-types": "openapi-typescript build/openapi.json -o src/types/api.generated.ts --export-type",
    "gen:api-types:from-monorepo": "openapi-typescript ../build/openapi.json -o src/types/api.generated.ts --export-type",
    "gen:ws-types": "json2ts build/ws-schemas.json -o src/types/ws.generated.ts --additionalProperties false",
    "gen:ws-types:from-monorepo": "json2ts ../build/ws-schemas.json -o src/types/ws.generated.ts --additionalProperties false",
    "gen": "node scripts/gen-from-backend.mjs",
    "icons:vendor": "node scripts/vendor-icons.mjs",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "e2e:debug": "playwright test --config e2e/playwright.config.ts --debug",
    "e2e:report": "playwright show-report playwright-report"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "json-schema-to-zod": "^2.8.1",
    "knip": "^6.12.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "puppeteer": "^24.43.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
