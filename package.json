{
  "name": "snapper-frontend",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateusz-klatt/snapper-frontend.git"
  },
  "homepage": "https://github.com/mateusz-klatt/snapper-frontend#readme",
  "bugs": {
    "url": "https://github.com/mateusz-klatt/snapper-frontend/issues"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --max-warnings=0 .",
    "lint:fix": "eslint --cache . --fix",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dead-code": "knip",
    "dead-code:fix": "knip --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:serial": "vitest run --maxWorkers=1 --no-file-parallelism",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:serial": "vitest run --coverage --maxWorkers=1 --no-file-parallelism",
    "gen:api-types": "openapi-typescript build/openapi.json -o src/types/api.generated.ts --export-type",
    "gen:api-types:from-monorepo": "openapi-typescript ../build/openapi.json -o src/types/api.generated.ts --export-type",
    "gen:ws-types": "json2ts build/ws-schemas.json -o src/types/ws.generated.ts --additionalProperties false",
    "gen:ws-types:from-monorepo": "json2ts ../build/ws-schemas.json -o src/types/ws.generated.ts --additionalProperties false",
    "gen": "bash scripts/gen-from-backend.sh",
    "icons:vendor": "bash scripts/vendor-icons.sh",
    "bundle:check": "node scripts/check-bundle-budget.mjs"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "uuid": "14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": ">=4.17.23",
      "jsdom": "26.1.0",
      "uuid": "14.0.0"
    },
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "26.1.0",
    "json-schema-to-typescript": "15.0.4",
    "json-schema-to-zod": "^2.8.1",
    "knip": "^6.11.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
